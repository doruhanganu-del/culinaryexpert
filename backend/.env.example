NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # admin operations (register, etc.)
SUPABASE_ANON_KEY=YOUR_ANON_KEY                   # user auth operations (login, refresh)

# JWT (from Supabase Auth)
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
